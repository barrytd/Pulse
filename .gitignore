# .gitignore
# -----------
# This file tells Git which files to IGNORE (not track or upload).
# We don't want to push temporary files, secrets, or giant log files
# to GitHub — just our source code.

# Python cache files (auto-generated when you run code)
__pycache__/
*.pyc

# Virtual environment (if you create one)
venv/
.venv/

# IDE settings (VS Code stores preferences here)
.vscode/

# Log files — these can be huge and are specific to each user.
# Match anywhere in the tree so stray copies in the project root never get committed.
*.evtx

# Generated reports — users will generate their own
reports/*.txt
reports/*.json
reports/*.html
reports/*.csv

# SQLite databases — each user has their own scan history
*.db

# Baseline snapshots — captured per-machine
pulse_baseline.json

# OS junk files
.DS_Store
Thumbs.db

# Environment variables / secrets (NEVER push these to GitHub)
.env

# Per-user config with secrets (session_secret, SMTP password, webhook URLs).
# Template lives in pulse.yaml.example — copy it to pulse.yaml locally.
pulse.yaml

# Claude Code settings (local to each developer, not needed in repo)
.claude/

# PyInstaller build artifacts (Sprint 7 — packaged Pulse Agent).
# `python scripts/build_agent.py` regenerates these on demand; the
# resulting pulse-agent.exe is shipped via GitHub Releases, not the
# source repo.
build/
dist/
